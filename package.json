{
  "name": "meal-planner",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "dev:tunnel": "tsx scripts/dev-tunnel.ts",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "db:generate": "cd packages/db && pnpm drizzle-kit generate",
    "db:migrate": "cd packages/db && pnpm drizzle-kit migrate",
    "db:studio": "cd packages/db && pnpm drizzle-kit studio",
    "import-promos": "tsx scripts/import-promos.ts"
  },
  "devDependencies": {
    "@meal-planner/db": "workspace:*",
    "@meal-planner/domain": "workspace:*",
    "turbo": "^2.5.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.0",
    "@types/node": "^22.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "overrides": {
      "@types/react": "19.1.17"
    }
  }
}
