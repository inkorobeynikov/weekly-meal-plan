# ── Database ──────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/meal_planner"

# ── Telegram Bot ──────────────────────────────────────────
BOT_TOKEN="your-telegram-bot-token"
# Webhook URL for production (set to empty for polling in dev)
BOT_WEBHOOK_URL=""

# ── OpenAI ────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."
# gpt-4o-mini for fast/cheap calls, gpt-4o for plan generation
OPENAI_MODEL_FAST="gpt-4o-mini"
OPENAI_MODEL_SMART="gpt-4o"

# ── Auth ──────────────────────────────────────────────────
# Must be at least 32 chars
JWT_SECRET="change-me-to-something-very-long-and-random"
JWT_EXPIRES_IN="30d"

# ── Inngest (background jobs) ─────────────────────────────
INNGEST_EVENT_KEY="local"
INNGEST_SIGNING_KEY=""

# ── App ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
